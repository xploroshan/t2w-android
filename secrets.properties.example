# Copy this file to `secrets.properties` (git-ignored) and fill in real values.
#   cp secrets.properties.example secrets.properties
# Every key is optional — absent keys fall back to safe defaults.
# See docs/SETUP_SECRETS.md for a step-by-step walkthrough.

# --- Backend API base URL (must end with a trailing slash) ---
# Debug builds run on the emulator; 10.0.2.2 is the host machine's localhost.
T2W_API_BASE_URL_DEBUG=http://10.0.2.2:3000/
# Release builds point at production.
T2W_API_BASE_URL=https://taleson2wheels.com/

# --- Google Maps SDK for Android (live-ride map) ---
# Google Cloud Console -> APIs & Services -> Credentials -> API key.
# Leave blank to ship without maps (tiles render blank).
MAPS_API_KEY=

# --- Mapbox PUBLIC access token (Relive 3D flyover) ---
# account.mapbox.com -> Tokens -> your public token (starts with "pk.").
# This is the RUNTIME token embedded in the app. Leave blank to ship without the
# 3D flyover (the Relive screen shows a "set token" hint). See docs/SETUP_SECRETS.md.
# NOTE: the separate build-time SECRET token (sk.*, Downloads:Read scope) does NOT
# go here — it goes in ~/.gradle/gradle.properties as MAPBOX_DOWNLOADS_TOKEN.
MAPBOX_ACCESS_TOKEN=

# --- Sentry crash reporting ---
# sentry.io -> Project Settings -> Client Keys (DSN).
# Leave blank to disable crash reporting.
SENTRY_DSN=
